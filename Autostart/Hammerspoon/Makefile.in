# Create an empty reldeps.mk if it does not already exist.
# prologue.mk unconditionally includes $(SRC_DIR)/reldeps.mk; this rule
# satisfies the include on a fresh source tree that has never been built.
$(SRC_DIR)/reldeps.mk:
	@touch "$@"

HAMMERSPOON_INSTALL_DIRECTORY = $(INSTALL_ROOT)$(datadir)/brltty/Autostart/Hammerspoon

install:
	$(INSTALL_DIRECTORY) $(HAMMERSPOON_INSTALL_DIRECTORY)
	$(INSTALL_DATA) $(SRC_DIR)/brltty.lua $(HAMMERSPOON_INSTALL_DIRECTORY)
	$(INSTALL_DATA) $(BLD_DIR)/sudoers.brltty $(HAMMERSPOON_INSTALL_DIRECTORY)

uninstall:
	-rm -f $(HAMMERSPOON_INSTALL_DIRECTORY)/brltty.lua
	-rm -f $(HAMMERSPOON_INSTALL_DIRECTORY)/sudoers.brltty
	-rmdir $(HAMMERSPOON_INSTALL_DIRECTORY) 2>/dev/null

clean::

distclean:: clean
	-rm -f sudoers.brltty
