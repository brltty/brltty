# Remove stale BrlAPI socket files only when brltty is not running.
# Stale sockets accumulate when brltty exits uncleanly (e.g. after a crash
# or after being killed), and prevent a new brltty instance from creating
# its BrlAPI socket.

brlapi_socket_dir="@api_socket_path@"

if pgrep -x brltty >/dev/null 2>&1; then
  exit 0
fi

# BrlAPI socket files are hidden (names begin with '.').
find "${brlapi_socket_dir}" -maxdepth 1 -name ".*" -delete 2>/dev/null

exit 0
