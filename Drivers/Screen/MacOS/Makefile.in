DRIVER_CODE = mo
DRIVER_NAME = MacOS
DRIVER_USAGE = MacOS operating system via its accessibility API
DRIVER_VERSION =
DRIVER_DEVELOPERS = Yannick Plassiard <plassiardyannick@gmail.com>
DRIVER_DEPENDENCIES = @screen_libraries_mo@
DRIVER_OBJECTS = screen.$O ax_bridge.$O
include $(SRC_TOP)screen.mk

screen.$O:
	$(CC) $(DRIVER_CFLAGS) -x objective-c -c $(SRC_DIR)/screen.m

ax_bridge.$O:
	$(CC) $(DRIVER_CFLAGS) -x objective-c -c $(SRC_DIR)/ax_bridge.m
