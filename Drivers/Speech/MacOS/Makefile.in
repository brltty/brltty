DRIVER_CODE = mo
DRIVER_NAME = MacOS
DRIVER_USAGE = macOS speech via AVSpeechSynthesizer
DRIVER_VERSION =
DRIVER_DEVELOPERS = Yannick Plassiard <plassiardyannick@gmail.com>
DRIVER_DEPENDENCIES = @speech_libraries_mo@
include $(SRC_TOP)speech.mk

speech.$O:
	$(CC) $(DRIVER_CFLAGS) -x objective-c -c $(SRC_DIR)/speech.m
