source [file join [file dirname [info script]] .. prologue.tcl]
source [file join $scriptDirectory csv.tcl]

set optionDefinitions {
   {check flag "test"}
}

processProgramArguments optionValues $optionDefinitions
cd [file join $sourceRoot $documentsSubdirectory]

array set tableHeaders {
   braille-driver {code name aliases others}
   speech-driver  {code name aliases}
   screen-driver  {code name}

   text-table        {name description}
   contraction-table {name description}
   attributes-table  {name description}
   keyboard-table    {name description}
}

proc makeLists {file} {
   set lists [dict create]
   set pattern {^#(\w+-(?:driver|table))\s+([-\w]+)\s*#\s*(.*?)\s*$}
   array set isDefinedArray {}

   forEachLine line $file {
      if {[regexp $pattern $line x directive operand comment]} {
         set list [string tolower $directive]
         set columns [linsert [lmap column [split $comment ";"] {string trim $column}] 0 $operand]

         if {$::optionValues(check)} {
            upvar 0 isDefinedArray($list,[string tolower $operand]) isDefined

            if {[info exists isDefined]} {
               logWarning "duplicate definition: $directive $operand"
            } else {
               set isDefined 1
            }

            checkDefinition $list $columns
         }

         dict lappend lists $list $columns
      }
   }

   return $lists
}

proc checkDefinition {list columns} {
   set handler "check[join [lmap word [split $list -] {string totitle $word}] ""]"

   try {
      $handler $columns
   } trap {TCL LOOKUP COMMAND} {} {
      logWarning "handler not defined: $handler"
      proc $handler {columns} {}
   }
}

proc checkBrailleDriver {columns} {
   checkDriver $columns braille $::brailleDriversSubdirectory {auto}
}

proc checkSpeechDriver {columns} {
   checkDriver $columns speech $::speechDriversSubdirectory {auto}
}

proc checkScreenDriver {columns} {
   checkDriver $columns screen $::screenDriversSubdirectory
}

proc checkTextTable {columns} {
   checkTable $columns text $::textTablesSubdirectory $::textTableExtension {auto}
}

proc checkContractionTable {columns} {
   checkTable $columns contraction $::contractionTablesSubdirectory $::contractionTableExtension {auto}
}

proc checkAttributesTable {columns} {
   checkTable $columns attributes $::attributesTablesSubdirectory $::attributesTableExtension
}

proc checkKeyboardTable {columns} {
   checkTable $columns keyboard $::keyboardTablesSubdirectory $::keyTableExtension {off}
}

proc checkDriver {columns type subdirectory {ignore {}}} {
   lassign $columns code name

   if {[lsearch -exact $ignore $code] < 0} {
      set makefile [file join $::sourceRoot $subdirectory $name Makefile.in]

      if {[file isfile $makefile]} {
      } else {
         logWarning "unrecognized $type drivder name: $name"
      }
   }
}

proc checkTable {columns type subdirectory extension {ignore {}}} {
   lassign $columns name

   if {[lsearch -exact $ignore $name] < 0} {
      set table [file join $::sourceRoot $subdirectory $name.$extension]

      if {![file isfile $table]} {
         logWarning "unrecognized $type table name: $name"
      }
   }
}

proc updateTables {lists} {
   set updated 0

   foreach name [dict keys $lists] {
      if {[updateTable $lists $name]} {
         set updated 1
      }
   }

   if {[updateDriverCodes $lists]} {
      set updated 1
   }

   return $updated
}

proc updateTable {lists name} {
   global tableHeaders

   if {[info exists tableHeaders($name)]} {
      set headers $tableHeaders($name)
      set rows [csvNormalizeRows [linsert [dict get $lists $name] 0 $headers] [llength $headers]]

      if {[regexp {^(.*)-driver$} $name x driverType]} {
         set usageColumn [list usage]
         set driversDirectory [file join $::sourceRoot $::driversSubdirectory [string totitle $driverType]]

         foreach columns [lrange $rows 1 end] {
            set driverName [lindex $columns 1]
            set driverUsage ""
            set makeFile [file join $driversDirectory $driverName Makefile.in]

            if {[file exists $makeFile]} {
               if {![getMakeFileProperty $makeFile DRIVER_USAGE driverUsage]} {
                  logWarning "missing driver usage: $makeFile$"
               }
            }

            lappend usageColumn $driverUsage
         }

         set rows [lmap columns $rows usage $usageColumn {
            linsert $columns end $usage
         }]
      }

      if {[replaceFile "$name.csv" [csvMakeTable $rows]]} {
         return 1
      }
   } else {
      logWarning "table headers not defined: $name"
   }

   return 0
}

proc updateDriverCodes {lists} {
   set drivers [dict create]

   foreach type {braille speech screen} {
      set directive "$type-driver"

      if {[dict exists $lists $directive]} {
         foreach columns [dict get $lists $directive] {
            set code [lindex $columns 0]
            set name [lindex $columns 1]

            if {![dict exists $drivers $code $name]} {
               dict set drivers $code $name [dict create types [list]]
            }

            dict with drivers $code $name {
               lappend types $type
            }
         }
      }
   }

   set headers {code name types}
   set rows [list $headers]

   foreach code [lsort [dict keys $drivers]] {
      set codeEntry [dict get $drivers $code]
      set names [lsort [dict keys $codeEntry]]

      if {[dict size $codeEntry] > 1} {
         logWarning "ambiguous driver code: $code ([join $names ", "])"
      }

      foreach name $names {
         set row [list $code $name]

         dict with codeEntry $name {
            lappend row [join $types ", "]
         }

         lappend rows $row
      }
   }

   return [replaceFile "driver-code.csv" [csvMakeTable $rows]]
}

if {![updateTables [makeLists "brltty.conf.in"]]} {
   logTask "no files updated"
}

exit 0
